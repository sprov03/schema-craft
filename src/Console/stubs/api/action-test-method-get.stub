/**
 * Template variables:
 *   {{ actionName }}       - Method name (e.g., "archive")
 *   {{ modelClass }}       - Model class (e.g., "Post")
 *   {{ modelVariable }}    - camelCase variable (e.g., "post")
 *   {{ factoryClass }}     - Factory class (e.g., "PostFactory")
 *   {{ routePrefix }}      - Full route prefix (e.g., "api/posts")
 *   {{ actionSlug }}       - Kebab-case action (e.g., "archive")
 */
    public function test_can_{{ actionName }}(): void
    {
        $user = UserFactory::createDefault();
        $this->actingAs($user, 'sanctum');

        ${{ modelVariable }} = {{ factoryClass }}::createDefault();

        $response = $this->getJson('/{{ routePrefix }}/' . ${{ modelVariable }}->id . '/{{ actionSlug }}');

        $response->assertOk();
    }
