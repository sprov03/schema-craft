{
    "name": "{{ packageName }}",
    "description": "API client SDK for {{ clientName }}",
    "version": "{{ version }}",
    "type": "library",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "{{ namespace }}\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
